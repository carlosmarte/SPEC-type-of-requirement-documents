  "elicitationStrategy": {
    "primaryTechniques": ["Workshop", "Interview", "Document Analysis"],
    "toolsUsed": ["Miro (Process Mapping)", "Zoom", "Confluence"],
    "keyActivities": [
      {
        "activityName": "As-Is Process Mapping",
        "technique": "Workshop",
        "targetStakeholders": ["Regional Sales Managers", "Customer Success Leads"],
        "expectedOutcome": "Document current pain points and manual workarounds in the legacy CRM."
      },
      {
        "activityName": "Data Migration Rules",
        "technique": "Document Analysis",
        "targetStakeholders": ["Data Engineering"],
        "expectedOutcome": "Map legacy database fields to the new CRM schema requirements."
      }
    ]
  },
  "requirementsLifecycle": {
    "repositoryTool": "Jira Software (Requirements via Epics/Stories)",
    "typesTracked": ["Business", "Functional", "Non-Functional", "Transition"],
    "prioritizationFramework": "MoSCoW (Must Have, Should Have, Could Have, Won't Have)",
    "validationSteps": [
      "1. BA drafts Story + Acceptance Criteria",
      "2. Peer review by Tech Lead for feasibility",
      "3. Review by QA for testability",
      "4. Formal sign-off by Product Owner/Sponsor (Moves to 'Ready for Dev')"
    ]
  },
  "traceabilityApproach": {
    "traceabilityTool": "Jira Advanced Roadmaps & Xray",
    "linkageModel": [
      "Business Objective (Confluence)",
      "Epic (Jira)",
      "User Story (Jira)",
      "Test Execution (Xray)",
      "Git Commit (Bitbucket)"
    ],
    "attributesTracked": ["Jira Status", "MoSCoW Priority", "Sponsor Sign-off Date", "Sprint Target"]
  },
  "changeControlProcess": {
    "changeRequestMechanism": "Submission of a 'Change Request' Jira issue type linked to the baselined Epic.",
    "impactAnalysisSLA": "72 hours for Engineering and BA to estimate cost/timeline impact.",
    "changeControlBoard": [
      "VP of Sales (Sponsor)",
      "Director of Engineering",
      "Lead Product Manager"
    ],
    "versioningScheme": "Stories are immutable once 'In Sprint'. Approved changes require cloning the story, suffixing with 'v2', and closing the original as 'Superseded'."
  },
